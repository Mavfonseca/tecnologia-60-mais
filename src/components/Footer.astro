---
const today = new Date();
---

<footer style="background-color: #000080; color: #ffffff; padding: 60px 20px; width: 100%; border-top: 4px solid #ff7f50;">
  <!-- Container centralizado que respira melhor -->
  <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 40px;">
    
    <!-- Coluna 1 -->
    <div style="display: flex; flex-direction: column;">
      <h3 style="color: #ff7f50; margin-top: 0; font-size: 1.2rem;">Tecnologia 60 Mais</h3>
      <p style="font-size: 0.9rem; line-height: 1.6; opacity: 0.9;">Tecnologia descomplicada e com paciência. Nosso objetivo é dar autonomia digital com segurança e clareza.</p>
    </div>

    <!-- Coluna 2 -->
    <div>
      <h4 style="color: #ff7f50; margin-top: 0; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">Conteúdos</h4>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <li style="margin-bottom: 10px;"><a href="/blog" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">Todos os Tutoriais</a></li>
        <li style="margin-bottom: 10px;"><a href="/blog" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">Segurança Digital</a></li>
        <li style="margin-bottom: 10px;"><a href="/blog" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">Dicas de WhatsApp</a></li>
      </ul>
    </div>

    <!-- Coluna 3 -->
    <div>
      <h4 style="color: #ff7f50; margin-top: 0; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">Sobre</h4>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <li style="margin-bottom: 10px;"><a href="/sobre" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">Sobre o Guia</a></li>
        <li style="margin-bottom: 10px;"><a href="/privacidade" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">Privacidade</a></li>
        <li style="margin-bottom: 10px;"><a href="/termos-de-uso" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">Termos de Uso</a></li>
        <li style="margin-bottom: 10px;"><a href="/contato" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">Contato</a></li>
      </ul>
    </div>

    <!-- Coluna 4: O Ecossistema -->
    <div>
      <h4 style="color: #ff7f50; margin-top: 0; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">Conheça Também</h4>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <li style="margin-bottom: 10px;">
          <a href="https://saudecomequilibrio.com.br/" target="_blank" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">
            🍏 Saúde com Equilíbrio
          </a>
        </li>
        <li style="margin-bottom: 10px;">
          <a href="https://temperosdonordeste.saudecomequilibrio.com.br/" target="_blank" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">
            🌶️ Temperos do Nordeste
          </a>
        </li>
        <li style="margin-bottom: 10px;">
          <a href="https://marcosvfonseca.com/" target="_blank" style="color: #ffffff; text-decoration: none; font-size: 0.9rem;">
            🌐 Marcos Fonseca
          </a>
        </li>
      </ul>
    </div>

  </div>

  <!-- Rodapé Inferior -->
  <div style="max-width: 1100px; margin: 40px auto 0 auto; border-top: 1px solid rgba(255,255,255,0.2); padding-top: 20px; text-align: center; font-size: 0.8rem; opacity: 0.8;">
    &copy; {today.getFullYear()} Tecnologia 60 Mais. Todos os direitos reservados.
    <br>
    <span style="margin-top: 5px; display: block;">Desenvolvido com ❤️ por Marcos Fonseca</span>
  </div>
</footer>