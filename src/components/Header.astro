---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header style="background-color: #000080; color: white; padding: 22px 20px; margin: 0; box-shadow: 0 4px 10px rgba(0,0,0,0.15); width: 100%; box-sizing: border-box;">
	<nav style="display: flex; align-items: center; justify-content: space-between; max-width: 1100px; margin: 0 auto;">
		<h2 style="margin: 0; font-size: 1.8rem;">
			<a href="/" style="color: white; text-decoration: none; font-weight: bold;">Tecnologia 60 Mais</a>
		</h2>
		<div class="nav-links" style="display: flex; align-items: center; gap: 30px;">
			<HeaderLink href="/" style="color: white; text-decoration: none; font-size: 1.1rem; font-weight: bold;">Casa</HeaderLink>
			<HeaderLink href="/blog" style="color: white; text-decoration: none; font-size: 1.1rem; font-weight: bold;">Blog</HeaderLink>
			<HeaderLink href="/sobre" style="color: white; text-decoration: none; font-size: 1.1rem; font-weight: bold;">Sobre</HeaderLink>
			
			<!-- Botão de Login -->
			<a href="#" style="border: 2px solid white; padding: 8px 20px; border-radius: 20px; color: white; text-decoration: none; font-weight: bold; transition: all 0.3s ease;">Login</a>
		</div>
	</nav>
</header>

<style>
	/* Efeito hover (piscar) no botão de Login */
	.nav-links a:last-child:hover {
		background-color: white;
		color: #000080 !important;
	}
	
	/* Responsividade para o celular */
	@media (max-width: 768px) {
		nav {
			flex-direction: column;
			gap: 15px;
		}
		.nav-links {
			gap: 15px;
			flex-wrap: wrap;
			justify-content: center;
		}
	}
</style>